# Django Settings
# Copy this file to .env and fill in your values

# REQUIRED: Generate a secure key with: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=your-secure-secret-key-here

# Set to False in production!
DEBUG=False

# Comma-separated list of allowed hosts (e.g., example.com,www.example.com)
ALLOWED_HOSTS=localhost,127.0.0.1

# Optional CORS settings (comma-separated)
# CORS_ALLOWED_ORIGINS=https://example.com

# Database (for PostgreSQL)
# DB_NAME=scienceportal
# DB_USER=postgres
# DB_PASSWORD=your-password
# DB_HOST=localhost
# DB_PORT=5432
